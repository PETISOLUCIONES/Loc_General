<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="wt_create_so_from_pos.ControlButtons" t-inherit="point_of_sale.ControlButtons"
       t-inherit-mode="extension">
        <xpath expr="//t[@t-if='props.showRemainingButtons']/div/NoteButton" position="before">
            <button t-if="pos.config.create_so" class="btn btn-secondary btn-lg py-5"
                    t-on-click="() => this.clickCreateSaleOrder()">
                <i class="o_button_icon fa fa-fw fa-pencil-square-o" aria-hidden="true"/>
                Create Sale Order
            </button>
        </xpath>
              <xpath expr="//button[./i[@class='fa fa-link me-1']]" position="replace">
            <button t-if="this.pos.cashier._role != 'minimal'"
                    t-att-class="buttonClass"
                    t-on-click="() => this.onClickQuotation()">
                <i class="fa fa-file-text-o"
                   role="img"
                   aria-label="View Sales Order"
                   title="View Sales Order"/>
                View Sales Order
            </button>
        </xpath>

    </t>
</templates>
