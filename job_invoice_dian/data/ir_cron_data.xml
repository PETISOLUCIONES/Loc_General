<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_requeue_failed_dian_jobs" model="ir.cron">
            <field name="name">DIAN: Reintentar jobs fallidos</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="state">code</field>
            <field name="code">model._cron_requeue_failed_dian_jobs()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="active">False</field>
        </record>

        <record id="ir_cron_retry_dian_connection_errors" model="ir.cron">
            <field name="name">DIAN: Reintentar facturas fallidas por error de conexión</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="state">code</field>
            <field name="code">model._cron_retry_dian_connection_errors()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="active">False</field>
        </record>
        <record id="ir_cron_send_invoice_failed" model="ir.cron">
            <field name="name">DIAN: Reintentar facturas fallidas por error de esquema</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="state">code</field>
            <field name="code">model._cron_send_invoice_failed()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="active">False</field>
        </record>
        <record id="ir_cron_redate_failed_invoices" model="ir.cron">
            <field name="name">DIAN: Actualizar fecha de facturas fallidas del día anterior</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="state">code</field>
            <field name="code">model._cron_redate_failed_invoices()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">months</field>
            <field name="numbercall">-1</field>
            <field name="nextcall">2026-05-02 05:00:10</field>
            <field name="active">False</field>
        </record>
    </data>
</odoo>